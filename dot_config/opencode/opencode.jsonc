{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": ["CONTRIBUTING.md", "docs/guidelines.md"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  // "mcp": {
  //   "context7": {
  //     "type": "remote",
  //     "url": "https://mcp.context7.com/mcp",
  //     "enabled": false 
  //   }
